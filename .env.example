# STT Terminal Tool Configuration

# Whisper server URL (speaches / faster-whisper OpenAI-compatible API).
# Point this at wherever you run the whisper container.
# Example remote server: http://192.168.30.30:8082/v1/audio/transcriptions
STT_SERVER_URL="http://localhost:8082/v1/audio/transcriptions"

# Language for transcription (ISO 639-1: "de", "en", or "auto" to auto-detect)
STT_LANGUAGE="de"

# UTF-8 locale used by macOS clipboard/paste helpers.
# Override only if your system does not provide de_DE.UTF-8.
STT_LOCALE="de_DE.UTF-8"

# ZSH in-terminal hotkey (^ = Ctrl). Used by stt.zsh widget. Cross-platform.
STT_HOTKEY="^T"

# Audio input device.
#   Linux (ALSA):      "default" (or a specific card like "hw:1,0")
#   macOS (CoreAudio): "default", empty, or a device name from System Settings > Sound > Input
#   Tip: choose a non-Bluetooth mic (e.g. "MacBook Pro Microphone" / "MacBook Pro-Mikrofon")
#        to keep AirPods/headphones in high-quality playback mode while recording.
STT_AUDIO_DEVICE="default"

# macOS only: if STT_AUDIO_DEVICE is empty/default and the default input is a
# Bluetooth headset mic, automatically record from a built-in/USB input instead.
# Set to 0 if you intentionally want the Bluetooth mic/bidirectional profile.
STT_MACOS_AVOID_BLUETOOTH_PROFILE_SWITCH="1"

# Whisper model (tiny, base, small, medium, large-v3)
STT_MODEL="Systran/faster-whisper-base"
STT_TRANSCRIBE_TIMEOUT="30"

# Optional post-processing after Whisper and before paste/insert.
# Disabled by default so STT still works when LM Studio is offline.
STT_POSTPROCESS_ENABLED="0"

# Provider:
#   lmstudio = LM Studio native REST API (/api/v1/chat), recommended for Qwen reasoning models
#   openai   = OpenAI-compatible chat completions API (/v1/chat/completions)
STT_POSTPROCESS_PROVIDER="lmstudio"

# LM Studio local server URL.
# Example remote AI server: http://192.168.30.30:1234/api/v1/chat
STT_POSTPROCESS_URL="http://localhost:1234/api/v1/chat"

# Text cleanup model. Tested: qwen/qwen3.5-9b with STT_POSTPROCESS_REASONING="off".
STT_POSTPROCESS_MODEL="qwen/qwen3.5-9b"
STT_POSTPROCESS_TIMEOUT="60"
STT_POSTPROCESS_WARN_SECONDS="20"
STT_AUTO_RAW_FALLBACK="1"
# Optional LM Studio idle-TTL (seconds) sent as the request-body `ttl` field.
# DEFAULT OFF: works only on OpenAI chat/completions-style endpoints; the
# Responses-style /api/v1/chat endpoint rejects it ("unrecognized keys: ttl").
# Prefer configuring the idle TTL in LM Studio itself: `lms load <model> --ttl
# 3600`, or set the JIT default in the Developer tab → Server Settings.
STT_POSTPROCESS_TTL=""
STT_POSTPROCESS_TEMPERATURE="0"
STT_POSTPROCESS_REASONING="off"
STT_POSTPROCESS_LOG_ENABLED="1"
STT_POSTPROCESS_LOG_FILE=""

# Path to a file holding the active LLM prompt. Managed by the macOS STTBar
# app (it mirrors the active prompt from prompts.json here). Used only when
# STT_POSTPROCESS_PROMPT is unset; an inline STT_POSTPROCESS_PROMPT still wins.
STT_POSTPROCESS_PROMPT_FILE=""

# Deterministic replacements applied before and after AI post-processing.
# File format is tab-separated: spoken-or-model-text<TAB>preferred-output
STT_REPLACEMENTS_ENABLED="1"
STT_REPLACEMENTS_FILE=""

# Runtime files used by STTBar and the shell backend. Defaults to
# ${TMPDIR:-/tmp}/de.projectmakers.stt when empty.
STT_RUNTIME_DIR=""

# Optional app comfort settings read by STTBar.
STT_MAX_RECORDING_SECONDS="1200"
STT_PREWARM_ENABLED="0"
STT_KEEP_MODEL_WARM_SECONDS="0"
STT_HISTORY_ENABLED="0"
STT_HISTORY_RETENTION_HOURS="24"
STT_SENSITIVE_MODE="0"

# Docker host port for the whisper server (container always listens on 8000 internally)
STT_DOCKER_PORT="8082"

# Model TTL: seconds idle before unloading from VRAM (-1=never, 0=immediate, >0=seconds)
STT_MODEL_TTL="-1"
